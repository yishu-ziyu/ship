{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CODEX_PLUGIN_ROOT}/scripts/session-start.sh\"",
            "statusMessage": "Loading Ship routing hint"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CODEX_PLUGIN_ROOT}/scripts/phase-guardrail.sh\"",
            "statusMessage": "Checking phase access rules"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CODEX_PLUGIN_ROOT}/scripts/stop-gate.sh\"",
            "statusMessage": "Checking Ship auto state",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
